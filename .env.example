# Copy to .env at the repo root. build.rs bakes these into the binary at compile
# time, so rebuild after changing them.

# GitHub OAuth App — required for the "Login with GitHub" button.
# Create one at https://github.com/settings/developers (New OAuth App):
#   Homepage URL:               http://localhost:3000
#   Authorization callback URL: http://localhost:2026/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Optional: PostgreSQL analytics database. Leave empty to run without it.
DATABASE_URL=

# ---------------------------------------------------------------------------
# You do NOT need the OAuth app to try LidBridge locally: on the login screen
# use "Use a token instead" and paste a GitHub Personal Access Token (classic,
# with the `repo` scope). That path needs no client id/secret.
# ---------------------------------------------------------------------------

# Optional: GitHub App private key (PEM) for organization pushes via a GitHub App.
# Prefer providing it as a file at src-tauri/src/keys/private-key.pem, or export
# GITHUB_APP_PRIVATE_KEY at runtime. Not needed for normal use.
