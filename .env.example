# =============================================================================
# LidBridge — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# =============================================================================

# GitHub OAuth App — required for the "Login with GitHub" button.
# Create one at https://github.com/settings/developers (New OAuth App):
#   Application name:               LidBridge
#   Homepage URL:                   http://localhost:3000
#   Authorization callback URL:     http://localhost:2026/callback
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Optional: PostgreSQL analytics database (DEPRECATED — not used in v2).
# Left empty to run without it. Will be re-enabled in a future update.
DATABASE_URL=
